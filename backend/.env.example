# Copy to backend/.env and fill in. Local dev works with the defaults below.

ENV=dev

# --- Database ---
# Local dev: SQLite (default). Prod: Supabase Postgres connection string, e.g.
# DATABASE_URL=postgresql+psycopg://postgres:<pwd>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=sqlite:///./syllabusslayer.db

# --- Supabase (auth + storage) ---
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=uploads

# --- OpenAI ---  (RE-VERIFY model ids + pricing before committing budget)
OPENAI_API_KEY=
OPENAI_MODEL_HEAVY=gpt-5.4
OPENAI_MODEL_MINI=gpt-5.4-mini
OPENAI_MODEL_NANO=gpt-5.4-nano
OPENAI_MODEL_ESCALATION=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- RAG ---
RAG_TOKEN_THRESHOLD=100000

# --- CORS ---  (JSON list)
CORS_ORIGINS=["http://localhost:3000"]
